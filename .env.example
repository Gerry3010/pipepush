# Copy to .env and fill in. Generate secrets with the commands below.

# Postgres password (used by both services in docker-compose)
POSTGRES_PASSWORD=change-me

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Public URL the app is served from (used for links/CORS)
BASE_URL=http://localhost:8080

# Web Push VAPID keys — generate with: pipepush-server -gen-vapid-keys
# (or: docker compose run --rm pipepush pipepush-server -gen-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com

# --- CLI / CI usage (not needed by the server) ---
# PIPEPUSH_SERVER=https://pipepush.example.com
# PIPEPUSH_TOKEN=pp_xxx
